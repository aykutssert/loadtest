# Copy this file to .env and fill in real values.
# These defaults work with docker-compose out of the box.
# For Coolify deployments, set each variable individually in the service settings.

# RabbitMQ
# In Coolify, RABBITMQ_HOST is the internal container hostname (check via `hostname` in the terminal).
# Do NOT use an amqp:// URI — Coolify can silently corrupt the scheme.
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# MongoDB
# Include the trailing slash. Use the internal hostname when running inside Coolify.
MONGODB_URL=mongodb://root:password@mongodb:27017/

# API only — tells ASP.NET Core which port to bind
ASPNETCORE_URLS=http://+:8080

# Optional: comma-separated hostnames/IPs to block as load test targets.
# Use this to prevent the tool from being pointed at your own infrastructure.
# Do not hardcode server IPs in source — set them here.
# BLOCKED_HOSTS=203.0.113.1,10.0.0.1
